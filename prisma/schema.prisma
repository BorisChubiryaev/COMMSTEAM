generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model TeamMember {
  id        String   @id @default(cuid())
  name      String
  avatar    String?
  role      String?
  email     String?

  // Telegram auth / DM delivery
  telegramId       String?  @unique // Telegram user id (used for login + DMs)
  telegramChatId   String?          // private chat id for direct messages
  telegramUsername String?

  // Bot-issued one-time login code
  loginCode          String?
  loginCodeExpiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  signals   Signal[] @relation("SignalAssignee")
  collaborations Signal[] @relation("SignalCollaborators")
  comments  Comment[]
  events    Event[]

  // Knowledge base / expertise
  expertise             MemberExpertise[]
  expertiseObservations ExpertiseObservation[]
}

// ── Knowledge base ───────────────────────────────────────────────────────────
// The portal accumulates "who knows what" by observing real activity (signals
// handled, events organised, comments) and rolling it up per member × topic.

model Topic {
  id           String                 @id @default(cuid())
  key          String                 @unique // stable slug, e.g. "ai", "security"
  label        String                 // human label, mirrors the meanings vocab
  kind         String                 @default("meaning") // meaning, skill
  expertise    MemberExpertise[]
  observations ExpertiseObservation[]
  createdAt    DateTime               @default(now())
}

// One atomic piece of evidence that a member knows a topic. Kept as a log so we
// always know *why* the score is what it is (provenance). Derived from activity,
// re-synced idempotently — never edited by hand.
model ExpertiseObservation {
  id         String     @id @default(cuid())
  memberId   String
  member     TeamMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  topicId    String
  topic      Topic      @relation(fields: [topicId], references: [id], onDelete: Cascade)
  sourceType String     // signal_assignee, signal_collaborator, event_organizer, comment
  signalId   String? // loose reference (no FK) — cleanup handled by sync helpers
  eventId    String?
  weight     Float      @default(1)
  occurredAt DateTime   @default(now())
  createdAt  DateTime   @default(now())

  @@index([memberId, topicId])
  @@index([signalId])
  @@index([eventId])
}

// Aggregated state per member × topic: this is what the graph and the
// "who knows X" recommender read. Recomputed from observations.
model MemberExpertise {
  id             String     @id @default(cuid())
  memberId       String
  member         TeamMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  topicId        String
  topic          Topic      @relation(fields: [topicId], references: [id], onDelete: Cascade)
  score          Float      @default(0)
  evidenceCount  Int        @default(0)
  lastActivityAt DateTime?
  aiSummary      String? // reserved for the future LLM summary pass
  updatedAt      DateTime   @updatedAt

  @@unique([memberId, topicId])
  @@index([topicId])
}

model Signal {
  id               String        @id @default(cuid())
  title            String
  content          String?
  link             String?
  aiSummary        String?

  // Source
  source           String?       // ДЗО, Трабы/Команды, Мероприятия, Тренды/Рынок, Задачи от руководства

  // Signal type
  signalType       String?       // Новость, Идея/Инициатива, Инфоповод, Задача/Поручение

  // Evaluation / Filter
  relevance        Int?          // 1-5 актуальность и значимость
  alignment        Int?          // 1-5 соответствие смыслам и целям
  urgency          Int?          // 1-5 срочность
  potential        String?       // PR, HR, Продукт, Репутация (comma separated)
  risks            String?       // риски и чувствительность

  // Priority
  priority         String?       // A, B, C, Отклонено

  // Meanings (comma-separated keys)
  meanings         String?       // ИИ, RecSys, СберID, Персонализация, Безопасность, HR-бренд, Технологическое лидерство

  // Distribution
  distribution     String?       // PR, Маркетинг, Внутриком (comma separated)

  // Launch
  publicationType  String?       // Посты в соцсетях, Статья, Пресс-релиз, Выступление, Внутренняя коммуникация, Мероприятие/Митап, Реклама
  aiContent        String?       // AI-generated content for publication
  published        Boolean       @default(false) // вышло в публикацию (для блока «Посты» в отчёте)
  postLinks        String?       // ссылки на площадки публикации (по строке на ссылку)
  launchDate       DateTime?     // Дата и время события/запуска
  launchLocation   String?       // Место события/запуска
  calendarEventId  String?       @unique
  calendarEvent    Event?        @relation("SignalCalendarEvent", fields: [calendarEventId], references: [id], onDelete: SetNull)

  // Status (workflow stage)
  status           String        @default("input") // input, classification, evaluation, meaning, distribution, launch, measurement, feedback, completed, archived

  // Measurement
  reach            Int?
  engagement       Int?
  mediaMentions    Int?
  traffic          Int?
  leads            Int?
  businessImpact   String?

  // Feedback
  whatWorked       String?
  whatDidntWork    String?
  newInsights      String?
  meaningMapUpdate String?

  // Relations
  assigneeId       String?
  assignee         TeamMember?   @relation("SignalAssignee", fields: [assigneeId], references: [id])
  collaborators    TeamMember[]  @relation("SignalCollaborators")
  contacts         Contact[]     @relation("SignalContacts")
  comments         Comment[]
  incomingNews     IncomingNews[]
  decisionHistory  DecisionHistory[]

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model IncomingNews {
  id                String   @id @default(cuid())
  title             String
  content           String?
  link              String?
  source            String   @default("manual") // telegram, manual, parser, rss
  status            String   @default("new") // new, converted, duplicate, ignored
  rawPayload        String?

  // AI pre-analysis
  aiSummary         String?
  aiSource          String?
  aiSignalType      String?
  aiRelevance       Int?
  aiAlignment       Int?
  aiUrgency         Int?
  aiPotential       String?
  aiRisks           String?
  aiPriority        String?
  aiMeanings        String?
  aiDistribution    String?
  aiPublicationType String?
  aiAnalyzedAt      DateTime?

  // Duplicate detection
  duplicateScore    Int?
  duplicateReason   String?
  duplicateOfId     String?
  duplicateOf       IncomingNews? @relation("IncomingNewsDuplicates", fields: [duplicateOfId], references: [id])
  duplicates        IncomingNews[] @relation("IncomingNewsDuplicates")

  telegramChatId    String?
  telegramMessageId String?
  telegramUsername  String?
  telegramFirstName String?
  telegramLastName  String?

  signalId          String?
  signal            Signal?  @relation(fields: [signalId], references: [id])
  decisionHistory   DecisionHistory[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([source, telegramChatId, telegramMessageId])
  @@index([status, createdAt])
  @@index([link])
  @@index([duplicateOfId])
  @@index([aiPriority])
}

model DecisionHistory {
  id             String        @id @default(cuid())
  action         String        // created, auto_analyzed, marked_duplicate, converted, ignored, restored, edited
  actor          String        @default("system")
  note           String?
  metadata       String?

  incomingNewsId String?
  incomingNews   IncomingNews? @relation(fields: [incomingNewsId], references: [id], onDelete: Cascade)
  signalId       String?
  signal         Signal?       @relation(fields: [signalId], references: [id], onDelete: Cascade)

  createdAt      DateTime      @default(now())

  @@index([incomingNewsId, createdAt])
  @@index([signalId, createdAt])
}

model Contact {
  id          String    @id @default(cuid())
  name        String
  company     String?
  role        String?
  email       String?
  phone       String?
  telegram    String?
  notes       String?
  tags        String?   // comma separated
  signals     Signal[]  @relation("SignalContacts")
  events      Event[]   @relation("EventContacts")
  comments    Comment[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Event {
  id          String      @id @default(cuid())
  title       String
  description String?
  date        DateTime
  endDate     DateTime?
  location    String?
  type        String?     // Мероприятие, Митап, Выступление, Встреча
  status      String      @default("planned") // planned, confirmed, completed, cancelled
  responsible String?     // ответственный для отчёта (если не пользователь портала)
  tentative   Boolean     @default(false) // предварительная/размытая дата
  dateText    String?     // как показывать дату в отчёте, напр. «Август ??»
  organizerId String?
  organizer   TeamMember? @relation(fields: [organizerId], references: [id])
  contacts    Contact[]   @relation("EventContacts")
  signal       Signal?     @relation("SignalCalendarEvent")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Comment {
  id         String      @id @default(cuid())
  content    String
  authorId   String
  author     TeamMember  @relation(fields: [authorId], references: [id])
  signalId   String?
  signal     Signal?     @relation(fields: [signalId], references: [id])
  contactId  String?
  contact    Contact?    @relation(fields: [contactId], references: [id])
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model PeriodSummary {
  id          String   @id @default(cuid())
  title       String
  periodStart DateTime
  periodEnd   DateTime
  aiSummary   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
